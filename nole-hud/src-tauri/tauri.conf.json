{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../",
    "distDir": "../"
  },
  "package": {
    "productName": "NoleAI HUD",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.noleai.hud",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "NoleAI",
        "width": 320,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true
      }
    ]
  }
}
